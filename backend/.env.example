DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=zeitstempel

# JWT – unbedingt einen langen, zufälligen String verwenden!
# Beispiel: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_use_a_long_random_secret_here

# JWT-Ablaufzeit (Standard: 8h). Gültige Werte: 1h, 30m, 8h, 1d, etc.
JWT_EXPIRY=8h
